<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MCA Department</title>

  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: linear-gradient(to right, #aa9094, #000000);
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
    }

    .card {
      background: white;
      width: 60%;
      max-width: 700px;
      padding: 30px;
      border-radius: 15px;
      text-align: center;
      box-shadow: 0 10px 25px rgba(0,0,0,0.2);
    }

    h1 {
      font-size: 28px;
      margin-bottom: 15px;
      color: #333;
    }

    h2 {
      font-size: 20px;
      color: #555;
      margin-top: 10px;
    }

    p {
      color: #777;
      margin-top: 5px;
    }

    img.logo {
      width: 180px;
      margin: 20px auto;
      display: block;
    }

    img.banner {
      width: 100%;
      border-radius: 10px;
      margin-top: 20px;
    }

    .highlight {
      color: #2c7be5;
      font-weight: bold;
    }
  </style>
</head>

<body>
  <div class="card">

    <h1>Welcome to Department of MCA (SSIT)</h1>

    <img class="logo"
      src="https://ssahe.edu.in/ssit/img/sri-siddhartha-institute-of-technology-ssit-logo.png" />

    <h1 class="highlight">My job is done with Jenkins & GitHub 🚀</h1>

    <h2>Welcome to SSIT on behalf of MCA Department</h2>
 </div>
</body>
</html>
